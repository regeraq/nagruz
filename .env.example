# ============================================================
#  Шаблон переменных окружения
# ============================================================
# Скопируйте этот файл в .env и заполните значения.
# НИКОГДА не коммитьте .env с реальными секретами в git!
#
# Файл .env уже в .gitignore — проверяйте историю git, если
# когда-то раньше он был закоммичен, ротируйте ВСЕ ключи.
# ============================================================

# ---------- База данных ----------
# Для продакшена используйте российский хостинг (242-ФЗ):
# Selectel, VK Cloud, Yandex Cloud, Timeweb, REG.RU, Beget.
DATABASE_URL=postgresql://user:password@host:5432/database

# ---------- Окружение ----------
NODE_ENV=production
PORT=5000

# Установите true, если приложение стоит за reverse-proxy (nginx)
# с корректно выставленными X-Forwarded-For / X-Forwarded-Proto.
# Если false — X-Forwarded-For игнорируется (защита от IP-спуфинга).
TRUST_PROXY=false

# Принудительно выдавать cookie с флагом Secure=true даже если
# сам Node.js видит HTTP (например, когда TLS терминируется на nginx).
FORCE_SECURE_COOKIES=false

# ---------- JWT секреты ----------
# Сгенерируйте каждый отдельно:
#   openssl rand -base64 48
# Минимум 32 символа. Никогда не переиспользуйте между окружениями.
JWT_SECRET=REPLACE_ME_WITH_STRONG_RANDOM_VALUE_MIN_32_CHARS
JWT_REFRESH_SECRET=REPLACE_ME_WITH_DIFFERENT_STRONG_RANDOM_VALUE_MIN_32_CHARS

# ---------- CSRF ----------
CSRF_SECRET=REPLACE_ME_WITH_ANOTHER_STRONG_RANDOM_VALUE_MIN_32_CHARS

# ---------- Email (отправка писем) ----------
# ВАЖНО: Resend = США. По 152-ФЗ ст.12 — это трансграничная передача
# ПД в страну, не обеспечивающую адекватную защиту. Требуется либо:
#   а) отдельное согласие субъекта ПД + уведомление Роскомнадзора;
#   б) переход на российский SMTP (Mail.ru for Business, Yandex.SMTP,
#      SendPulse рос. сегмент, UniSender).
RESEND_API_KEY=
OWNER_EMAIL=owner@example.ru
RESEND_FROM_EMAIL=noreply@yourdomain.ru

# ---------- URL фронтенда ----------
FRONTEND_URL=https://yourdomain.ru

# ---------- Дополнительные опции (необязательно) ----------
# DEBUG_CSRF=true — включает подробные логи CSRF-проверок.
#DEBUG_CSRF=false
