# ============================================================
#  Шаблон переменных окружения
# ============================================================
# Скопируйте этот файл в .env и заполните значения.
# НИКОГДА не коммитьте .env с реальными секретами в git!
#
# Файл .env уже в .gitignore — проверяйте историю git, если
# когда-то раньше он был закоммичен, ротируйте ВСЕ ключи.
# ============================================================

# ---------- База данных ----------
# Для продакшена используйте российский хостинг (242-ФЗ):
# Selectel, VK Cloud, Yandex Cloud, Timeweb, REG.RU, Beget.
DATABASE_URL=postgresql://user:password@host:5432/database

# ---------- Окружение ----------
NODE_ENV=production
PORT=5000

# Установите true, если приложение стоит за reverse-proxy (nginx)
# с корректно выставленными X-Forwarded-For / X-Forwarded-Proto.
# Если false — X-Forwarded-For игнорируется (защита от IP-спуфинга).
TRUST_PROXY=false

# Принудительно выдавать cookie с флагом Secure=true даже если
# сам Node.js видит HTTP (например, когда TLS терминируется на nginx).
FORCE_SECURE_COOKIES=false

# ---------- JWT секреты ----------
# Сгенерируйте каждый отдельно:
#   openssl rand -base64 48
# Минимум 32 символа. Никогда не переиспользуйте между окружениями.
JWT_SECRET=REPLACE_ME_WITH_STRONG_RANDOM_VALUE_MIN_32_CHARS
JWT_REFRESH_SECRET=REPLACE_ME_WITH_DIFFERENT_STRONG_RANDOM_VALUE_MIN_32_CHARS

# ---------- CSRF ----------
CSRF_SECRET=REPLACE_ME_WITH_ANOTHER_STRONG_RANDOM_VALUE_MIN_32_CHARS

# ---------- Email (отправка писем) ----------
# Провайдер выбирается одной переменной:
#   yandex  — Yandex Cloud Postbox (рекомендуется: серверы в РФ, 152-ФЗ)
#   resend  — Resend (legacy, США; только для обратной совместимости)
#   noop    — ничего не отправлять (dev/CI)
EMAIL_PROVIDER=yandex

# Общие настройки отправителя (используются всеми провайдерами).
# MAIL_FROM_EMAIL должен быть в подтверждённом в Postbox домене/идентичности.
OWNER_EMAIL=owner@yourdomain.ru
MAIL_FROM_EMAIL=noreply@yourdomain.ru
MAIL_FROM_NAME=Loaddevice

# ---------- Yandex Cloud Postbox (основной провайдер) ----------
# Получите на https://console.yandex.cloud → Сервисные аккаунты →
# ваш аккаунт → API-ключи → "Статический ключ доступа".
# Подробности: DEPLOYMENT_GUIDE.md §13.
YANDEX_POSTBOX_KEY_ID=
YANDEX_POSTBOX_SECRET=
# Регион и хост можно не трогать (значения по умолчанию подходят).
#YANDEX_POSTBOX_REGION=ru-central1
#YANDEX_POSTBOX_HOST=postbox.cloud.yandex.net
#YANDEX_POSTBOX_PORT=465

# ---------- Resend (опциональный fallback) ----------
# Используется только при EMAIL_PROVIDER=resend.
# ПРЕДУПРЕЖДЕНИЕ: Resend = США. По 152-ФЗ ст.12 это трансграничная
# передача ПД, требуется либо отдельное согласие субъекта, либо
# переход на российского провайдера (Yandex Postbox выше).
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.ru

# ---------- URL фронтенда ----------
FRONTEND_URL=https://yourdomain.ru

# ---------- Дополнительные опции (необязательно) ----------
# DEBUG_CSRF=true — включает подробные логи CSRF-проверок.
#DEBUG_CSRF=false
